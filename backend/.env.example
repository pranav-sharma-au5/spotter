# ── Local dev ──────────────────────────────────────────────────────────────
MAPS_API_KEY=your-ors-api-key-here
ORS_BASE_URL=https://api.openrouteservice.org
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Local verification suite (SQLite + saved route plans — not for Vercel)
ENABLE_VERIFICATION=1

# ── Vercel production (set these in the Vercel dashboard) ──────────────────
# SECRET_KEY=<generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">
# DEBUG=False
# ALLOWED_HOSTS=<your-project>.vercel.app,<your-custom-domain.com>
# MAPS_API_KEY=<your-ors-api-key>
# ORS_BASE_URL=https://api.openrouteservice.org
#
# Frontend (Vercel → Environment Variables — applies at build time)
# Do NOT set VITE_API_URL to localhost on production; leave unset so the app calls
# same-origin /api/* (required for mobile). Backend vars for Vercel:
# SECRET_KEY, DEBUG=False, MAPS_API_KEY, ALLOWED_HOSTS=<your-domain>
